{
  "name": "stitch-and-soul-fashion-template",
  "version": "1.0.0",
  "description": "Premium African fashion designer website template — Stitch & Soul Studio",
  "scripts": {
    "build": "tailwindcss -i ./assets/css/input.css -o ./assets/css/style.css --minify",
    "watch": "tailwindcss -i ./assets/css/input.css -o ./assets/css/style.css --watch",
    "dev": "tailwindcss -i ./assets/css/input.css -o ./assets/css/style.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0"
  },
  "keywords": ["fashion", "tailoring", "african", "ankara", "template", "tailwindcss"],
  "license": "MIT"
}
